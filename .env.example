# Database
DATABASE_URL="file:./dev.db"

# NextAuth — AUTH_URL must include the /api/auth path (Auth.js v5)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000/api/auth"

# LinkedIn OAuth — create an app at https://www.linkedin.com/developers/apps
# Redirect URL: http://localhost:3000/api/auth/callback/linkedin
AUTH_LINKEDIN_ID=""
AUTH_LINKEDIN_SECRET=""

# Legacy aliases (also supported)
# LINKEDIN_CLIENT_ID=""
# LINKEDIN_CLIENT_SECRET=""

# Job scan cron (protect the /api/jobs/scan endpoint)
CRON_SECRET="your-cron-secret"

# Email notifications (optional — Resend)
RESEND_API_KEY=""
EMAIL_FROM="Job Bridge <notifications@yourdomain.com>"

# Development: use mock job data when LinkedIn API unavailable
USE_MOCK_JOBS="true"
# Job search source when USE_MOCK_JOBS=false:
#   guest    — public LinkedIn job listings (default, rate-limited)
#   official — partner-only API (likely unavailable; falls back to guest)
#   mock     — synthetic data
LINKEDIN_JOB_SOURCE="guest"
# Minimum delay between LinkedIn API requests in milliseconds (default 2500)
LINKEDIN_RATE_LIMIT_MS="2500"
# Set to true only for UI demos without LinkedIn API access
USE_MOCK_LINKEDIN_PROFILE="false"

# LinkedIn profile data tier (requires "Verified on LinkedIn" on your developer app)
#   basic        — sign-in only: name, email, photo (default)
#   development  — + profile URL via r_profile_basicinfo
#   lite         — same as development
#   plus         — + current job and most recent education
# After changing, sign out and sign in again.
LINKEDIN_PROFILE_TIER="basic"
# Or override scopes directly:
# LINKEDIN_OAUTH_SCOPES="openid profile email r_profile_basicinfo r_verify r_primary_current_experience r_most_recent_education"
